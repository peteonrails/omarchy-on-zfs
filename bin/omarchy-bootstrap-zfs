#!/bin/bash

# omarchy:summary=Bootstrap a fresh Omarchy install on ZFS-on-root with ZFSBootMenu (run from Arch live ISO).
# omarchy:args=[--dry-run] [--resume]
# omarchy:requires-sudo=true
#
# Runs from an Arch Linux live ISO as root. Performs the Phase 0 work that
# `omarchy/install.sh` doesn't: partitioning, zpool/dataset creation,
# pacstrap, chroot config, ZBM install, EFI boot entry. Then hands off to
# `install.sh` inside the chroot.
#
# This is the automated equivalent of docs/zfs-install.md.
#
# Usage:
#   omarchy-bootstrap-zfs                     # interactive
#   omarchy-bootstrap-zfs --dry-run           # print actions, change nothing
#   omarchy-bootstrap-zfs --resume            # resume from last completed stage
#
# Scope:
#   - Single disk OR multi-disk (mirror, raidz1, raidz2, raidz3)
#   - Fresh pool OR import of an existing pool (Appendix A dual-boot)
#   - Encrypted whole-pool with passphrase, file-based key for password sync
#   - Single ESP on the first member disk (ESP-mirror is a follow-up)
#   - Arch-wiki-style dataset layout: zroot/ROOT/default + zroot/data + zroot/var
#   - zfs-dkms-git built from a pinned OpenZFS commit (avoids the archzfs
#     release-lag-vs-kernel trap we hit on kernel 7.x). Override the commit
#     via OMARCHY_OPENZFS_REF.

set -euo pipefail

# ============================================================================
# Constants
# ============================================================================

readonly POOL_NAME="zroot"
# Arch-wiki dataset layout — discoverable by ZBM (ROOT/<be>) and granular
# enough that snapshot/rollback can target individual subsystems.
readonly DATASET_ROOT_CONTAINER="${POOL_NAME}/ROOT"
readonly DATASET_ROOT="${DATASET_ROOT_CONTAINER}/default"
readonly DATASET_DATA="${POOL_NAME}/data"
readonly DATASET_HOME="${DATASET_DATA}/home"
readonly DATASET_USER_ROOT="${DATASET_DATA}/root"
readonly DATASET_VAR="${POOL_NAME}/var"
readonly DATASET_VARLOG="${DATASET_VAR}/log"
readonly DATASET_VARLOG_JOURNAL="${DATASET_VARLOG}/journal"
readonly DATASET_VARCACHE="${DATASET_VAR}/cache"
readonly DATASET_VARTMP="${DATASET_VAR}/tmp"
readonly DATASET_VARLIB="${DATASET_VAR}/lib"
readonly DATASET_VARLIB_DOCKER="${DATASET_VARLIB}/docker"
readonly DATASET_VARLIB_LIBVIRT="${DATASET_VARLIB}/libvirt"
readonly DATASET_VARLIB_MACHINES="${DATASET_VARLIB}/machines"
readonly DATASET_KEYSTORE="${POOL_NAME}/keystore"

readonly KEYFILE_TMP="/tmp/omarchy-bootstrap.key"
readonly KEYFILE_FINAL="/etc/zfs/keys/${POOL_NAME}.key"

readonly STATE_FILE="/tmp/omarchy-bootstrap-zfs.state"
readonly LOG_FILE="/tmp/omarchy-bootstrap-zfs.log"

readonly ARCHZFS_KEY="DDF7DB817396A49B2A2723F7403BD972F75D9D76"
# Latest stable release EFI, served via redirect by the ZBM project.
readonly ZBM_RELEASE_URL="https://get.zfsbootmenu.org/efi"

# Pin OpenZFS to a specific master-branch commit when building zfs-dkms-git.
# Override via OMARCHY_OPENZFS_REF=<sha> if a newer commit is needed before
# we cut the next bootstrap release. Default commit is on master with
# Linux-Maximum: 7.0 — avoids the "archzfs release lags new kernel" trap.
readonly OPENZFS_GIT_REF="${OMARCHY_OPENZFS_REF:-0a59f7845c2863b5370bfa38e4d397ba3d73b62a}"
readonly ZFS_GIT_BUILD_DIR="/tmp/omarchy-zfs-git-build"
readonly ZFS_GIT_PKG_DIR="/tmp/omarchy-zfs-git-pkgs"
readonly ZFS_GIT_BUILD_USER="omarchy-zfs-build"

readonly MNT="/mnt"
readonly ESP_MOUNT="${MNT}/boot/efi"

# ============================================================================
# Globals (populated by stages)
# ============================================================================

DRY_RUN=0
RESUME=0
USE_EXISTING_POOL=0
TARGET_DISKS=()
POOL_TOPOLOGY=""
ESP_DEVICE=""
ZFS_PARTITIONS=()
HOSTNAME_VAL=""
TIMEZONE_VAL=""
LOCALE_VAL=""
USERNAME_VAL=""

# ============================================================================
# Logging + helpers
# ============================================================================

log()  { printf '[%s] %s\n' "$(date +%H:%M:%S)" "$*" >> "$LOG_FILE"; }
say()  { printf '\n\033[1;36m▸ %s\033[0m\n' "$*"; log "$*"; }
warn() { printf '\033[1;33m! %s\033[0m\n' "$*" >&2; log "WARN: $*"; }
die()  { printf '\033[1;31m✗ %s\033[0m\n' "$*" >&2; log "DIE: $*"; exit 1; }

run() {
  log "RUN: $*"
  if (( DRY_RUN )); then
    printf '\033[1;90m[dry-run]\033[0m %s\n' "$*"
    return 0
  fi
  "$@"
}

confirm() {
  local prompt="$1"
  if (( DRY_RUN )); then
    printf '\033[1;90m[dry-run]\033[0m would prompt: %s\n' "$prompt"
    return 0
  fi
  gum confirm "$prompt"
}

mark_done() { echo "$1" >> "$STATE_FILE"; }
is_done()   { [[ -f $STATE_FILE ]] && grep -qFx "$1" "$STATE_FILE"; }

stage() {
  local name="$1"
  local fn="stage_${name}"
  if (( RESUME )) && is_done "$name"; then
    say "Skipping ${name} (already done)"
    return 0
  fi
  say "${name//_/ }"
  "$fn"
  mark_done "$name"
}

# ============================================================================
# Argument parsing
# ============================================================================

usage() {
  sed -n '3,/^$/p' "$0" | sed 's/^# \?//'
  exit "${1:-0}"
}

parse_args() {
  while (( $# )); do
    case "$1" in
      --dry-run) DRY_RUN=1 ;;
      --resume)  RESUME=1 ;;
      -h|--help) usage 0 ;;
      *) die "Unknown argument: $1" ;;
    esac
    shift
  done
}

# ============================================================================
# Stage 1: preflight
# ============================================================================

stage_preflight() {
  [[ $EUID -eq 0 ]] || die "Must run as root"
  [[ -d /sys/firmware/efi ]] || die "UEFI mode required (Secure Boot must be off)"

  if ! command -v gum &>/dev/null; then
    say "Installing gum on the live ISO"
    run pacman -Sy --noconfirm --needed gum
  fi

  if ! ping -c1 -W2 archlinux.org &>/dev/null; then
    die "No network. Set up wifi (iwctl) or ethernet first."
  fi

  log "preflight ok: euid=$EUID, efi=yes, network=yes"
}

# ============================================================================
# Stage 2: build zfs-dkms-git / zfs-utils-git from a pinned OpenZFS commit
#
# We pin instead of pulling archzfs's released zfs-dkms because archzfs lags
# OpenZFS upstream by weeks-to-months — and OpenZFS master may have
# Linux-Maximum support for kernel versions that the released archzfs
# package doesn't yet build against. Using the git PKGBUILD with a pinned
# upstream commit gets us the support we need without depending on the
# archzfs release cadence.
#
# Built packages also get carried into the chroot via stage_pacstrap so the
# target system has the same versions.
# ============================================================================

stage_install_zfs_on_iso() {
  if modinfo zfs &>/dev/null && command -v zpool &>/dev/null; then
    say "ZFS already available on this ISO"
    run modprobe zfs
    return 0
  fi

  say "Building zfs-utils-git and zfs-dkms-git from OpenZFS @ $OPENZFS_GIT_REF"
  say "(this takes ~5–10 min the first time; pinned commit avoids archzfs lag)"

  run pacman -Sy --noconfirm
  run pacman -S --noconfirm --needed base-devel git linux-headers dkms

  if (( DRY_RUN )); then
    log "would clone, sed-pin, and makepkg zfs-{utils,dkms}-git"
    return 0
  fi

  rm -rf "$ZFS_GIT_BUILD_DIR" "$ZFS_GIT_PKG_DIR"
  mkdir -p "$ZFS_GIT_BUILD_DIR" "$ZFS_GIT_PKG_DIR"

  if ! id -u "$ZFS_GIT_BUILD_USER" >/dev/null 2>&1; then
    useradd -m -s /bin/bash "$ZFS_GIT_BUILD_USER"
  fi
  printf '%s ALL=(ALL:ALL) NOPASSWD: ALL\n' "$ZFS_GIT_BUILD_USER" \
    > "/etc/sudoers.d/${ZFS_GIT_BUILD_USER}"
  chmod 440 "/etc/sudoers.d/${ZFS_GIT_BUILD_USER}"
  chown -R "${ZFS_GIT_BUILD_USER}:${ZFS_GIT_BUILD_USER}" "$ZFS_GIT_BUILD_DIR"

  for pkg in zfs-utils-git zfs-dkms-git; do
    sudo -u "$ZFS_GIT_BUILD_USER" git clone --depth 1 \
      "https://aur.archlinux.org/${pkg}.git" "${ZFS_GIT_BUILD_DIR}/${pkg}"
    sed -i \
      "s|git+https://github.com/openzfs/zfs.git|git+https://github.com/openzfs/zfs.git#commit=${OPENZFS_GIT_REF}|" \
      "${ZFS_GIT_BUILD_DIR}/${pkg}/PKGBUILD"
    chown -R "${ZFS_GIT_BUILD_USER}:${ZFS_GIT_BUILD_USER}" "${ZFS_GIT_BUILD_DIR}/${pkg}"
  done

  # Build utils first — dkms package depends on it.
  sudo -u "$ZFS_GIT_BUILD_USER" bash -lc \
    "cd '${ZFS_GIT_BUILD_DIR}/zfs-utils-git' && MAKEFLAGS='-j$(nproc)' makepkg --noconfirm --syncdeps --needed"
  pacman -U --noconfirm "${ZFS_GIT_BUILD_DIR}"/zfs-utils-git/zfs-utils-git-[0-9]*.pkg.tar.zst

  sudo -u "$ZFS_GIT_BUILD_USER" bash -lc \
    "cd '${ZFS_GIT_BUILD_DIR}/zfs-dkms-git' && MAKEFLAGS='-j$(nproc)' makepkg --noconfirm --syncdeps --needed"
  pacman -U --noconfirm "${ZFS_GIT_BUILD_DIR}"/zfs-dkms-git/zfs-dkms-git-[0-9]*.pkg.tar.zst

  # Stash the built packages so stage_pacstrap can install them in the chroot
  # without rebuilding (DKMS will rebuild against the chroot's kernel headers).
  cp "${ZFS_GIT_BUILD_DIR}"/zfs-utils-git/zfs-utils-git-[0-9]*.pkg.tar.zst "$ZFS_GIT_PKG_DIR/"
  cp "${ZFS_GIT_BUILD_DIR}"/zfs-dkms-git/zfs-dkms-git-[0-9]*.pkg.tar.zst "$ZFS_GIT_PKG_DIR/"

  modprobe zfs
  command -v zpool &>/dev/null || die "ZFS install succeeded but zpool not on PATH"
}

# ============================================================================
# Stage 3: choose pool mode (fresh or existing)
# ============================================================================

stage_choose_pool_mode() {
  local importable
  importable=$(zpool import 2>/dev/null | awk '/^   pool:/ {print $2}' || true)

  if [[ -n $importable ]]; then
    say "Detected importable pools:"
    echo "$importable" | sed 's/^/  /'
    if confirm "Add Omarchy as a boot environment on an existing pool?"; then
      USE_EXISTING_POOL=1
    fi
  fi

  if (( USE_EXISTING_POOL )); then
    log "mode: existing pool"
  else
    log "mode: fresh pool"
  fi
}

# ============================================================================
# Stage 4 (fresh): disk + topology selection
# ============================================================================

stage_disk_selection() {
  if (( USE_EXISTING_POOL )); then return 0; fi

  say "Pick pool topology"
  POOL_TOPOLOGY=$(printf '%s\n' single mirror raidz1 raidz2 raidz3 \
    | gum choose --header "Topology")
  [[ -n $POOL_TOPOLOGY ]] || die "No topology selected"

  local min
  case "$POOL_TOPOLOGY" in
    single) min=1 ;;
    mirror) min=2 ;;
    raidz1) min=3 ;;
    raidz2) min=4 ;;
    raidz3) min=5 ;;
  esac

  say "Pick ${min}+ disks (Tab to multi-select; first disk also gets the ESP)"
  local choices
  choices=$(lsblk -dpno NAME,SIZE,MODEL,TYPE | awk '$NF=="disk"' \
    | gum choose --no-limit --header "Disks (≥${min})")
  [[ -n $choices ]] || die "No disks selected"

  mapfile -t TARGET_DISKS < <(echo "$choices" | awk '{print $1}')
  (( ${#TARGET_DISKS[@]} >= min )) || die "$POOL_TOPOLOGY needs at least $min disks"

  warn "All data on these disks will be DESTROYED:"
  printf '  %s\n' "${TARGET_DISKS[@]}"
  confirm "Wipe and partition?" || die "Aborted"
}

# ============================================================================
# Stage 5 (fresh): partition disks
# ============================================================================

stage_partition_disks() {
  if (( USE_EXISTING_POOL )); then return 0; fi

  ZFS_PARTITIONS=()

  for i in "${!TARGET_DISKS[@]}"; do
    local disk="${TARGET_DISKS[$i]}"
    say "Partitioning $disk"
    run wipefs -af "$disk"
    run sgdisk -Z "$disk"

    if (( i == 0 )); then
      # ESP on first disk
      run sgdisk -n "1:0:+1G" -t "1:EF00" -c "1:EFI" "$disk"
      run sgdisk -n "2:0:0"   -t "2:BF00" -c "2:zfs" "$disk"
      ESP_DEVICE="$(_partition_path "$disk" 1)"
      ZFS_PARTITIONS+=("$(_partition_path "$disk" 2)")
    else
      # Subsequent disks: one ZFS partition spanning whole disk
      run sgdisk -n "1:0:0" -t "1:BF00" -c "1:zfs" "$disk"
      ZFS_PARTITIONS+=("$(_partition_path "$disk" 1)")
    fi
  done

  run partprobe
  sleep 2

  say "Formatting ESP at $ESP_DEVICE"
  run mkfs.fat -F32 -n EFI "$ESP_DEVICE"
}

_partition_path() {
  # Compose the partition device path. NVMe/SDA differ in how partitions are named.
  local disk="$1" num="$2"
  if [[ $disk =~ nvme|mmcblk|loop ]]; then
    echo "${disk}p${num}"
  else
    echo "${disk}${num}"
  fi
}

# ============================================================================
# Stage 6 (fresh): create pool
# ============================================================================

stage_create_pool() {
  if (( USE_EXISTING_POOL )); then return 0; fi

  say "Set the pool encryption passphrase (also used as your login password)"
  local pass1 pass2
  while :; do
    pass1=$(gum input --password --header "Passphrase (≥8 chars)")
    pass2=$(gum input --password --header "Confirm")
    [[ ${#pass1} -ge 8 && $pass1 == "$pass2" ]] && break
    warn "Mismatch or too short — try again"
  done

  if (( DRY_RUN )); then
    log "would write keyfile $KEYFILE_TMP"
  else
    umask 077
    printf '%s' "$pass1" > "$KEYFILE_TMP"
  fi

  local vdev_spec
  case "$POOL_TOPOLOGY" in
    single) vdev_spec="${ZFS_PARTITIONS[0]}" ;;
    mirror) vdev_spec="mirror ${ZFS_PARTITIONS[*]}" ;;
    raidz1) vdev_spec="raidz ${ZFS_PARTITIONS[*]}" ;;
    raidz2) vdev_spec="raidz2 ${ZFS_PARTITIONS[*]}" ;;
    raidz3) vdev_spec="raidz3 ${ZFS_PARTITIONS[*]}" ;;
  esac

  say "Creating pool $POOL_NAME ($POOL_TOPOLOGY)"
  # -R /mnt sets the altroot so child datasets mount under /mnt without
  # rewriting their mountpoint properties. After reboot, no altroot is
  # active and the same datasets mount at their literal mountpoints.
  # shellcheck disable=SC2086
  run zpool create -f \
    -o ashift=12 \
    -o autotrim=on \
    -O acltype=posixacl -O xattr=sa -O dnodesize=auto \
    -O compression=zstd \
    -O normalization=formD \
    -O relatime=on -O atime=off \
    -O mountpoint=none \
    -O canmount=off \
    -O encryption=aes-256-gcm \
    -O keyformat=passphrase \
    -O keylocation="file://$KEYFILE_TMP" \
    -R "$MNT" \
    "$POOL_NAME" $vdev_spec
}

# ============================================================================
# Stage 7 (existing): import pool, load key
# ============================================================================

stage_import_existing_pool() {
  if ! (( USE_EXISTING_POOL )); then return 0; fi

  say "Importing $POOL_NAME"
  run zpool import -f -N "$POOL_NAME"

  if [[ $(zfs get -H -o value keystatus "$POOL_NAME") != "available" ]]; then
    say "Loading pool key"
    if (( DRY_RUN )); then
      log "would prompt for $POOL_NAME passphrase"
    else
      zfs load-key "$POOL_NAME"
    fi
  fi

  if zfs list -H -o name | grep -qx "$DATASET_ROOT_CONTAINER"; then
    die "$DATASET_ROOT_CONTAINER already exists. Refusing to clobber."
  fi

  # Find the existing ESP — caller's other OS will have one mounted somewhere
  if [[ -z $ESP_DEVICE ]]; then
    ESP_DEVICE=$(lsblk -no NAME,FSTYPE,PATH | awk '$2=="vfat"{print $3; exit}')
    [[ -n $ESP_DEVICE ]] || die "Could not auto-detect ESP. Set ESP_DEVICE env var."
    say "Reusing detected ESP: $ESP_DEVICE"
  fi
}

# ============================================================================
# Stage 8: dataset layout (Arch-wiki-style)
#
# Pool root carries the encryption (set in stage_create_pool); all child
# datasets inherit. Mountpoints are stored in the pool itself so
# zfs-mount-generator can reconstruct the tree at boot.
#
#   zroot/ROOT/default        →  /            (the boot environment)
#   zroot/data/home           →  /home
#   zroot/data/root           →  /root
#   zroot/var/log             →  /var/log
#   zroot/var/log/journal     →  /var/log/journal   (posixacl for systemd)
#   zroot/var/cache           →  /var/cache
#   zroot/var/tmp             →  /var/tmp
#   zroot/var/lib/{docker,libvirt,machines}        (per-service, opt rollback)
#   zroot/keystore            →  /etc/zfs/keys
# ============================================================================

stage_create_datasets() {
  # Container datasets (no mount, no children inherit a mountpoint)
  run zfs create -o mountpoint=none -o canmount=off "$DATASET_ROOT_CONTAINER"
  run zfs create -o mountpoint=none -o canmount=off "$DATASET_DATA"
  run zfs create -o mountpoint=none -o canmount=off "$DATASET_VAR"
  run zfs create -o mountpoint=none -o canmount=off "$DATASET_VARLIB"

  # Boot environment — ZBM expects <pool>/ROOT/<name> with mountpoint=/ +
  # canmount=noauto. The "default" suffix is the BE name.
  run zfs create -o mountpoint=/ -o canmount=noauto "$DATASET_ROOT"

  # User-data datasets (shared across boot environments by default)
  run zfs create -o mountpoint=/home "$DATASET_HOME"
  run zfs create -o mountpoint=/root "$DATASET_USER_ROOT"

  # /var subtree — separate datasets so a system rollback doesn't nuke
  # logs / pacman cache, and per-service rollback is possible.
  run zfs create -o mountpoint=/var/log "$DATASET_VARLOG"
  run zfs create -o mountpoint=/var/log/journal -o acltype=posixacl "$DATASET_VARLOG_JOURNAL"
  run zfs create -o mountpoint=/var/cache "$DATASET_VARCACHE"
  run zfs create -o mountpoint=/var/tmp "$DATASET_VARTMP"
  run zfs create -o mountpoint=/var/lib/docker "$DATASET_VARLIB_DOCKER"
  run zfs create -o mountpoint=/var/lib/libvirt "$DATASET_VARLIB_LIBVIRT"
  run zfs create -o mountpoint=/var/lib/machines "$DATASET_VARLIB_MACHINES"

  # Encryption key storage — mounted at /etc/zfs/keys so the keyfile is
  # available post-import for the password-sync logic in install.sh.
  if ! zfs list -H -o name | grep -qx "$DATASET_KEYSTORE"; then
    run zfs create -o mountpoint=/etc/zfs/keys "$DATASET_KEYSTORE"
  fi

  # Pool-level boot pointer for ZBM convenience.
  run zpool set "bootfs=$DATASET_ROOT" "$POOL_NAME"
}

# ============================================================================
# Stage 9: mount filesystems for pacstrap
# ============================================================================

stage_mount_filesystems() {
  run mkdir -p "$MNT"
  run mount -t zfs -o zfsutil "$DATASET_ROOT" "$MNT"

  # Mount everything else by letting ZFS resolve mountpoints relative to /mnt
  # via altroot. zpool was created with -R /mnt in stage_create_pool, so
  # `zfs mount -a` mounts each dataset at "$MNT/<mountpoint>".
  run zfs mount -a

  run mkdir -p "$ESP_MOUNT"
  run mount "$ESP_DEVICE" "$ESP_MOUNT"
}

# ============================================================================
# Stage 10: pacstrap base + zfs (using the pre-built git packages)
# ============================================================================

stage_pacstrap() {
  say "pacstrap (≈5 min)"
  run pacstrap -K "$MNT" \
    base base-devel linux linux-firmware linux-headers \
    sudo git iwd \
    efibootmgr dosfstools \
    dkms

  # Install the pre-built zfs-utils-git / zfs-dkms-git packages in the chroot.
  # DKMS will rebuild the module against the chroot's installed kernel headers.
  if [[ -d $ZFS_GIT_PKG_DIR ]] && compgen -G "$ZFS_GIT_PKG_DIR/zfs-*.pkg.tar.zst" >/dev/null; then
    if (( DRY_RUN )); then
      log "would install zfs-utils-git and zfs-dkms-git in chroot from $ZFS_GIT_PKG_DIR"
    else
      install -d "$MNT/var/cache/omarchy/zfs-git-pkgs"
      cp "$ZFS_GIT_PKG_DIR"/*.pkg.tar.zst "$MNT/var/cache/omarchy/zfs-git-pkgs/"
      arch-chroot "$MNT" pacman -U --noconfirm \
        /var/cache/omarchy/zfs-git-pkgs/zfs-utils-git-[0-9]*.pkg.tar.zst \
        /var/cache/omarchy/zfs-git-pkgs/zfs-dkms-git-[0-9]*.pkg.tar.zst
    fi
  fi
}

# ============================================================================
# Stage 11: genfstab + ZFS entries
# ============================================================================

stage_fstab() {
  if (( DRY_RUN )); then
    log "would genfstab and append ZFS entries"
    return 0
  fi

  # genfstab captures the ESP. ZFS datasets are intentionally NOT in fstab —
  # zfs-mount-generator (driven by zfs-zed + the cachefile) handles them at
  # boot, and double-mount conflicts are easy to introduce by mixing fstab
  # entries with zfs-mount-generator-managed mounts.
  genfstab -U "$MNT" | grep -v ' zfs ' >> "$MNT/etc/fstab"
}

# ============================================================================
# Stage 12: chroot config (locale, hostname, user, networking, keystore, cachefile)
# ============================================================================

prompt_chroot_basics() {
  HOSTNAME_VAL=$(gum input --header "Hostname" --value "omarchy")
  TIMEZONE_VAL=$(gum input --header "Timezone (e.g. America/New_York)" --value "UTC")
  LOCALE_VAL=$(gum input  --header "Locale" --value "en_US.UTF-8")
  USERNAME_VAL=$(gum input --header "Username" --value "$(logname 2>/dev/null || echo user)")
  [[ -n $HOSTNAME_VAL && -n $TIMEZONE_VAL && -n $LOCALE_VAL && -n $USERNAME_VAL ]] \
    || die "All chroot prompts are required"
}

stage_chroot_config() {
  prompt_chroot_basics

  say "Writing system identity"
  if ! (( DRY_RUN )); then
    echo "$HOSTNAME_VAL" > "$MNT/etc/hostname"
    arch-chroot "$MNT" ln -sf "/usr/share/zoneinfo/$TIMEZONE_VAL" /etc/localtime
    arch-chroot "$MNT" hwclock --systohc
    echo "$LOCALE_VAL UTF-8" > "$MNT/etc/locale.gen"
    arch-chroot "$MNT" locale-gen
    echo "LANG=$LOCALE_VAL" > "$MNT/etc/locale.conf"
    echo "KEYMAP=us"        > "$MNT/etc/vconsole.conf"
  fi

  say "Networking (systemd-networkd + iwd)"
  if ! (( DRY_RUN )); then
    arch-chroot "$MNT" systemctl enable systemd-networkd.service systemd-resolved.service iwd.service
    mkdir -p "$MNT/etc/systemd/network" "$MNT/etc/iwd"
    cat > "$MNT/etc/systemd/network/20-wired.network" <<EOF
[Match]
Name=en*

[Network]
DHCP=yes
DNSSEC=no
EOF
    cat > "$MNT/etc/systemd/network/25-wireless.network" <<EOF
[Match]
Name=wl*

[Network]
DHCP=yes
DNSSEC=no
EOF
    cat > "$MNT/etc/iwd/main.conf" <<EOF
[General]
EnableNetworkConfiguration=false

[Network]
NameResolvingService=systemd
EOF
    arch-chroot "$MNT" ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
  fi

  say "Creating user $USERNAME_VAL"
  if ! (( DRY_RUN )); then
    arch-chroot "$MNT" useradd -m -G wheel,audio,video,input,storage,lp,sys,network,users,rfkill "$USERNAME_VAL"
    # Login password = encryption passphrase (install.sh's password-sync code does
    # the same thing on first run; we set it here so the user can log in immediately
    # after reboot in case install.sh password-sync is skipped via OMARCHY_CHROOT_INSTALL).
    if [[ -r $KEYFILE_TMP ]]; then
      printf '%s\n%s\n' "$(cat "$KEYFILE_TMP")" "$(cat "$KEYFILE_TMP")" \
        | arch-chroot "$MNT" passwd "$USERNAME_VAL"
    fi
    echo '%wheel ALL=(ALL) NOPASSWD: ALL' > "$MNT/etc/sudoers.d/wheel"
    chmod 440 "$MNT/etc/sudoers.d/wheel"
  fi

  say "Persisting key into ${DATASET_KEYSTORE} and switching to file-based keylocation"
  if ! (( DRY_RUN )); then
    install -m 600 "$KEYFILE_TMP" "$MNT$KEYFILE_FINAL"
    # Run change-key inside the chroot so the file:// path resolves correctly.
    # The kernel ZFS state is shared between live ISO and chroot, so this
    # updates the same imported pool either way.
    arch-chroot "$MNT" zfs change-key -o "keylocation=file://$KEYFILE_FINAL" "$POOL_NAME"
  fi

  say "Setting zpool cachefile"
  run zpool set "cachefile=/etc/zfs/zpool.cache" "$POOL_NAME"
  if ! (( DRY_RUN )); then
    mkdir -p "$MNT/etc/zfs"
    cp /etc/zfs/zpool.cache "$MNT/etc/zfs/zpool.cache"
  fi

  say "Setting org.zfsbootmenu:commandline"
  run zfs set "org.zfsbootmenu:commandline=quiet splash rw" "$DATASET_ROOT"
}

# ============================================================================
# Stage 13: install ZBM (prebuilt EFI to /boot/efi/EFI/zbm)
#
# We install the prebuilt release EFI for an immediate working boot. Omarchy's
# install.sh deposits the branded hooks at /etc/zfsbootmenu/hooks/ but only
# rebuilds via `generate-zbm` if zfs-bootmenu is installed (AUR). Branding is
# therefore deferred — re-run `omarchy-refresh-zbm` after first boot once the
# user has yay + zfsbootmenu via the AUR.
# ============================================================================

stage_install_zbm() {
  local zbm_dir="${ESP_MOUNT}/EFI/zbm"
  run mkdir -p "$zbm_dir"

  say "Downloading prebuilt ZBM EFI image"
  if ! (( DRY_RUN )); then
    curl -fsSL --location -o "$zbm_dir/vmlinuz.EFI" "$ZBM_RELEASE_URL" \
      || die "Failed to download ZBM EFI image from $ZBM_RELEASE_URL"
  fi

  # Stage Omarchy's branding hooks into the chroot now so the post-install
  # `generate-zbm` (run by install.sh) picks them up immediately if the user
  # later installs zfsbootmenu via AUR.
  if ! (( DRY_RUN )); then
    mkdir -p "$MNT/etc/zfsbootmenu/hooks/setup.d" "$MNT/etc/zfsbootmenu/hooks/load-key.d"
    cat > "$MNT/etc/zfsbootmenu/config.yaml" <<EOF
Global:
  ManageImages: true
  BootMountPoint: /boot/efi
  InitCPIO: true
  PreHooksDir: /etc/zfsbootmenu/hooks
Components:
  Enabled: false
EFI:
  Enabled: true
  ImageDir: /boot/efi/EFI/zbm
  Versions: 2
Kernel:
  CommandLine: quiet loglevel=0 zbm.skip_hooks=
EOF
  fi
}

# ============================================================================
# Stage 14: EFI boot entry for ZBM
# ============================================================================

stage_efi_boot_entry() {
  local first_disk="${TARGET_DISKS[0]:-}"
  local part_num=1

  if (( USE_EXISTING_POOL )); then
    # Derive disk + partition from ESP_DEVICE (e.g. /dev/nvme0n1p1 → nvme0n1, 1)
    first_disk=$(lsblk -no PKNAME "$ESP_DEVICE" | head -1)
    [[ -n $first_disk ]] || die "Could not derive parent disk from $ESP_DEVICE"
    first_disk="/dev/$first_disk"
    part_num=$(echo "$ESP_DEVICE" | grep -oE '[0-9]+$')
  fi

  if efibootmgr | grep -q "Omarchy (ZBM)"; then
    warn "EFI entry 'Omarchy (ZBM)' already exists — skipping"
    return 0
  fi

  say "Adding EFI boot entry"
  run efibootmgr --create \
    --disk "$first_disk" \
    --part "$part_num" \
    --label "Omarchy (ZBM)" \
    --loader '\EFI\zbm\vmlinuz.EFI'
}

# ============================================================================
# Stage 15: hand off to omarchy/install.sh inside the chroot
# ============================================================================

stage_run_omarchy_install() {
  # Clone our fork into the chroot user's home and run install.sh from there.
  # This mirrors how a user would normally run omarchy except we avoid the
  # curl-pipe-bash because install.sh expects to live at $HOME/.local/share/omarchy.
  local user_home="/home/$USERNAME_VAL"
  local target="$user_home/.local/share/omarchy"

  if (( DRY_RUN )); then
    log "would clone repo and run install.sh in chroot as $USERNAME_VAL"
    return 0
  fi

  arch-chroot "$MNT" sudo -u "$USERNAME_VAL" mkdir -p "$user_home/.local/share"
  arch-chroot "$MNT" sudo -u "$USERNAME_VAL" \
    git clone "${OMARCHY_BOOTSTRAP_REPO:-https://github.com/peteonrails/omarchy-on-zfs.git}" "$target"
  arch-chroot "$MNT" sudo -u "$USERNAME_VAL" \
    git -C "$target" checkout "${OMARCHY_BOOTSTRAP_BRANCH:-omarchy-zfs}"

  # OMARCHY_CHROOT_INSTALL=1 tells limine-snapper.sh's password-sync block to skip
  # — we already set the user password to match the encryption passphrase above.
  arch-chroot "$MNT" sudo -u "$USERNAME_VAL" \
    env OMARCHY_CHROOT_INSTALL=1 OMARCHY_PATH="$target" bash "$target/install.sh"
}

# ============================================================================
# Stage 16: finalize
# ============================================================================

stage_finalize() {
  say "Unmounting"
  if ! (( DRY_RUN )); then
    sync
    umount -R "$MNT" || warn "Some mounts didn't unmount cleanly"
    zpool export "$POOL_NAME" || warn "Pool export failed (will be auto-imported on boot regardless)"
  fi

  printf '\n\033[1;32m✓ Bootstrap complete.\033[0m\n\n'
  cat <<EOF
Next:
  - reboot
  - ZFSBootMenu shows the encryption passphrase prompt (your $POOL_NAME passphrase)
  - select ${DATASET_ROOT}
  - log in as $USERNAME_VAL with the same passphrase

Branding follow-up (after first boot):
  - install yay (or paru)
  - yay -S zfsbootmenu
  - sudo generate-zbm    # rebuilds ZBM with the Omarchy hooks staged in /etc/zfsbootmenu/hooks

Logs: $LOG_FILE
EOF
}

# ============================================================================
# Main
# ============================================================================

main() {
  parse_args "$@"
  : > "$LOG_FILE"
  (( RESUME )) || : > "$STATE_FILE"

  stage preflight
  stage install_zfs_on_iso
  stage choose_pool_mode

  if (( USE_EXISTING_POOL )); then
    stage import_existing_pool
  else
    stage disk_selection
    stage partition_disks
    stage create_pool
  fi

  stage create_datasets
  stage mount_filesystems
  stage pacstrap
  stage fstab
  stage chroot_config
  stage install_zbm
  stage efi_boot_entry
  stage run_omarchy_install
  stage finalize
}

main "$@"
