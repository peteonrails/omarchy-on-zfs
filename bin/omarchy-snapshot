#!/bin/bash

# omarchy:summary=Create or restore system snapshots with snapper
# omarchy:args=<create|restore>
# omarchy:requires-sudo=true

set -e

COMMAND="$1"
OMARCHY_PATH=${OMARCHY_PATH:-$HOME/.local/share/omarchy}

if [[ -z $COMMAND ]]; then
  echo "Usage: omarchy-snapshot <create|restore>" >&2
  exit 1
fi

if omarchy-fs-zfs; then
  if ! command -v zfs &>/dev/null; then
    exit 127
  fi

  POOL=$(zfs list -H -o name / | cut -d/ -f1)

  case "$COMMAND" in
  create)
    DESC="$(omarchy-version)"
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    SNAP_NAME="${TIMESTAMP}_${DESC// /-}"

    echo -e "\e[32mCreate ZFS system snapshot\e[0m"
    sudo zfs snapshot -r "${POOL}@${SNAP_NAME}"
    echo
    ;;
  restore)
    DATASET=$(zfs list -H -o name /)
    SNAP=$(sudo zfs list -t snapshot -H -o name -s creation "$DATASET" | \
      gum choose --header "Select snapshot to restore")

    if [[ -n $SNAP ]]; then
      if gum confirm "Rollback to $SNAP? This will destroy later snapshots."; then
        sudo zfs rollback -r "$SNAP"
        echo "Rollback complete. Reboot recommended."
      fi
    fi
    ;;
  esac
else
  if ! command -v snapper &>/dev/null; then
    exit 127 # omarchy-update can use this to just ignore if snapper is not available
  fi

  case "$COMMAND" in
  create)
    DESC="$(omarchy-version)"

    echo -e "\e[32mCreate system snapshot\e[0m"

    # Get existing snapper config names from CSV output
    mapfile -t CONFIGS < <(sudo snapper --csvout list-configs | awk -F, 'NR>1 {print $1}')

    for config in "${CONFIGS[@]}"; do
      sudo snapper -c "$config" create -c number -d "$DESC"
      sudo snapper -c "$config" cleanup number
    done
    echo
    ;;
  restore)
    sudo limine-snapper-restore
    ;;
  esac
fi
