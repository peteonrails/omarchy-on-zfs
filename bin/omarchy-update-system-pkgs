#!/bin/bash

# omarchy:summary=Update system packages with pacman
# omarchy:requires-sudo=true

set -e

# Bootstrap ZFS-related guards BEFORE the pacman transaction:
#   - archzfs repo (so zfs-dkms / zfs-utils have a current source)
#   - kernel compatibility guard (alpm hook + IgnorePkg)
# Both are idempotent — no-op if already in place. No-op on btrfs systems.
if command -v omarchy-fs-zfs &>/dev/null && omarchy-fs-zfs; then
  if [[ -f $OMARCHY_PATH/install/config/zfs-archzfs-repo.sh ]]; then
    bash "$OMARCHY_PATH/install/config/zfs-archzfs-repo.sh" || true
  fi
  if [[ -f $OMARCHY_PATH/install/config/zfs-kernel-guard.sh ]]; then
    bash "$OMARCHY_PATH/install/config/zfs-kernel-guard.sh" || true
  fi

  # Pre-update safety net: a ZFS snapshot of the BE so a failed update
  # can be rolled back. Upstream's omarchy-snapshot exits 127 on ZFS
  # (no snapper), so we take the snapshot ourselves here.
  if command -v omarchy-zfs-snapshot &>/dev/null; then
    omarchy-zfs-snapshot create || true
  fi
fi

echo -e "\e[32m\nUpdate system packages\e[0m"
sudo pacman -Syyu --noconfirm
